{
  "name": "netflix-jellyfin",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "build": {
    "appId": "com.streamvault.app",
    "productName": "StreamVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron-main.js",
      "package.json",
      "public/icon-192.png"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/icon-192.png"
    }
  },
  "scripts": {
    "dev": "next dev",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "electron-builder -w",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@movie-web/providers": "^2.4.13",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.99.1",
    "@vercel/analytics": "^2.0.1",
    "adm-zip": "^0.5.16",
    "framer-motion": "^12.34.5",
    "hls.js": "^1.6.15",
    "jose": "^6.2.1",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "node-fetch": "^3.3.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-intersection-observer": "^10.0.3",
    "srt-parser-2": "^1.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
